# ============================================================
#  named_clocks — переменные окружения
#  Скопируй в .env и заполни своими значениями:
#    cp .env.example .env
# ============================================================

# --- Вход в само приложение (один пользователь) ---
APP_LOGIN=admin
APP_PASSWORD=ZtA9TuxwZYUtjPk5X8NJrMy0Z1YADBycS
# Секрет для подписи JWT сессии сайта (смени на случайную строку)
JWT_SECRET=change-me-to-a-long-random-string-ZtA9TuxwZYUtjPk5X8NJrMy0Z1YADBycS

# --- Postgres ---
POSTGRES_USER=clocks
POSTGRES_PASSWORD=clocksZtA9TuxwZYUtjPk5X8NJrMy0Z1YADBycS
POSTGRES_DB=clocks
# DSN, которым пользуется backend внутри docker-сети
DATABASE_URL=postgres://clocks:clocksZtA9TuxwZYUtjPk5X8NJrMy0Z1YADBycS@postgres:5432/clocks?sslmode=disable

# --- MinIO (S3) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123ZtA9TuxwZYUtjPk5X8NJrMy0Z1YADBycS
# Внутренний адрес MinIO (docker-сеть)
MINIO_ENDPOINT=minio:9000
# Публичный адрес, по которому браузер сможет скачать видео (presigned url)
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_BUCKET=videos
MINIO_USE_SSL=false

# --- Imanator (генерация изображений) ---
# API-ключ (Bearer). Возьми из личного кабинета imanator.pro
IMANATOR_API_KEY=random-key
IMANATOR_BASE_URL=https://imanator.pro

# --- OpenRouter (генерация видео) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Модель видео по умолчанию (список подтягивается с OpenRouter на фронт)
OPENROUTER_DEFAULT_MODEL=google/veo-3.1
# Прокси для запросов к OpenRouter (если регион сервера заблокирован).
# Формат: http://user:pass@ip:port  (оставь пустым, чтобы ходить напрямую)
OPENROUTER_PROXY_URL=
# Таймаут одного HTTP-запроса к OpenRouter, сек (через прокси лучше побольше)
OPENROUTER_TIMEOUT_SECONDS=120

# --- Курс валют ---
# Резервный курс USD→RUB. Используется, если не удалось получить
# актуальный курс с ЦБ РФ (cbr-xml-daily.ru).
USD_RUB_RATE=85

# --- Воркер ---
# Сколько задач обрабатывать параллельно
WORKER_CONCURRENCY=4
# Интервал поллинга статусов, сек
POLL_INTERVAL_SECONDS=2
# Таймаут ожидания одного этапа, сек
STAGE_TIMEOUT_SECONDS=600

# --- Сервер ---
HTTP_PORT=8080
